{
  "manifest_version": 3,

  "name": "Napirajz Newtab",
  "description": "Not so useful plugin which shows random napirajz images on newtab opening.",
  "version": "2.0.0",
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },
  "icons": {
    "16": "icons/napirajz-logo16.png",
    "48": "icons/napirajz-logo48.png",
    "128": "icons/napirajz-logo.png"
  },
  "permissions": ["storage"],
  "host_permissions": [
    "https://kereso.napirajz.hu/*",
    "https://napirajz.hu/*"
  ]
}
